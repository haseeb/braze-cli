{
  "name": "@braze-oss/mcp",
  "version": "0.1.0",
  "description": "Braze MCP server — campaign/canvas/segment/content-block tools plus gated change and AI workflows, over stdio and HTTP",
  "type": "module",
  "license": "MIT",
  "keywords": ["braze", "mcp", "model-context-protocol", "martech", "ai-agents"],
  "repository": {
    "type": "git",
