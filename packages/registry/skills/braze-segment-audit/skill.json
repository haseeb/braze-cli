{
  "id": "braze-segment-audit",
  "name": "Braze Segment Audit",
  "version": "1.0.0",
  "description": "Identify cleanup opportunities and governance risks in Braze segments.",
  "category": "governance",
  "requires": {
    "mcp": "@braze-oss/mcp >=0.1.0",
    "permissions": ["segments.read"]
  },
  "entry": "SKILL.md",
  "prompts": ["prompts/segment-audit.md"],
  "harnesses": {
    "claude-code": { "type": "agent-skill", "path": "SKILL.md" },
    "codex": { "type": "instructions", "adapter": "adapters/codex.md" },
    "goose": { "type": "recipe", "adapter": "adapters/goose.yaml" },
    "hermes": { "type": "instructions", "adapter": "adapters/hermes.md" },
    "openclaw": { "type": "instructions", "adapter": "adapters/openclaw.md" },
    "generic": { "type": "prompt", "path": "SKILL.md" }
  },
  "tags": ["braze", "segments", "governance", "audit"],
  "license": "MIT",
  "author": "braze-oss"
}
