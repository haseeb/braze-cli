{
  "id": "braze-copy-studio",
  "name": "Braze Copy Studio",
  "version": "1.0.0",
  "description": "Generate and stage copy variants for campaigns with draft tokens.",
  "category": "copy",
  "requires": {
    "mcp": "@braze-oss/mcp >=0.1.0",
    "permissions": [
      "copy.generate"
    ]
  },
  "entry": "SKILL.md",
  "harnesses": {
    "claude-code": {
      "type": "agent-skill",
      "path": "SKILL.md"
    },
    "codex": {
      "type": "instructions",
      "adapter": "adapters/codex.md"
    },
    "goose": {
      "type": "recipe",
      "adapter": "adapters/goose.yaml"
    },
    "generic": {
      "type": "prompt",
      "path": "SKILL.md"
    }
  },
  "tags": [
    "braze",
    "copy",
    "generation",
    "draft"
  ],
  "license": "MIT",
  "author": "braze-oss"
}
