{
  "id": "braze-release-checklist",
  "name": "Braze Release Checklist",
  "version": "1.0.0",
  "description": "Validate Braze release readiness with a go/no-go checklist from staging to prod.",
  "category": "operations",
  "requires": {
    "mcp": "@braze-oss/mcp >=0.1.0",
    "permissions": [
      "campaigns.read",
      "canvases.read",
      "segments.read",
      "content_blocks.read"
    ]
  },
  "entry": "SKILL.md",
  "prompts": [
    "prompts/release-checklist.md"
  ],
  "harnesses": {
    "claude-code": {
      "type": "agent-skill",
      "path": "SKILL.md"
    },
    "codex": {
      "type": "instructions",
      "adapter": "adapters/codex.md"
    },
    "goose": {
      "type": "recipe",
      "adapter": "adapters/goose.yaml"
    },
    "generic": {
      "type": "prompt",
      "path": "SKILL.md"
    }
  },
  "tags": [
    "braze",
    "release",
    "deployment",
    "checklist"
  ],
  "license": "MIT",
  "author": "braze-oss"
}
