{
  "id": "braze-decisioning-setup",
  "name": "Braze Decisioning Studio Setup",
  "version": "1.0.0",
  "description": "Scaffold a Decisioning Studio experiment with variants, goals, and audience targeting.",
  "category": "decisioning",
  "requires": {
    "mcp": "@braze-oss/mcp >=0.1.0",
    "permissions": [
      "decisioning.scaffold",
      "decisioning.report"
    ]
  },
  "entry": "SKILL.md",
  "harnesses": {
    "claude-code": {
      "type": "agent-skill",
      "path": "SKILL.md"
    },
    "codex": {
      "type": "instructions",
      "adapter": "adapters/codex.md"
    },
    "goose": {
      "type": "recipe",
      "adapter": "adapters/goose.yaml"
    },
    "generic": {
      "type": "prompt",
      "path": "SKILL.md"
    }
  },
  "tags": [
    "braze",
    "decisioning",
    "experiment",
    "scaffold"
  ],
  "license": "MIT",
  "author": "braze-oss"
}
