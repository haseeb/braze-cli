{
  "id": "braze-liquid-doctor",
  "name": "Braze Liquid Doctor",
  "version": "1.0.0",
  "description": "Lint and preview Liquid templates to catch syntax errors before they reach production.",
  "category": "liquid",
  "requires": {
    "mcp": "@braze-oss/mcp >=0.1.0",
    "permissions": [
      "liquid.lint",
      "liquid.preview"
    ]
  },
  "entry": "SKILL.md",
  "harnesses": {
    "claude-code": {
      "type": "agent-skill",
      "path": "SKILL.md"
    },
    "codex": {
      "type": "instructions",
      "adapter": "adapters/codex.md"
    },
    "goose": {
      "type": "recipe",
      "adapter": "adapters/goose.yaml"
    },
    "generic": {
      "type": "prompt",
      "path": "SKILL.md"
    }
  },
  "tags": [
    "braze",
    "liquid",
    "lint",
    "templates"
  ],
  "license": "MIT",
  "author": "braze-oss"
}
