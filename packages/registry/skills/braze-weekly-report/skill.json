{
  "id": "braze-weekly-report",
  "name": "Braze Weekly Performance Report",
  "version": "1.0.0",
  "description": "Pull KPIs and synthesize a wins/risks/actions report for weekly standups.",
  "category": "reporting",
  "requires": {
    "mcp": "@braze-oss/mcp >=0.1.0",
    "permissions": [
      "campaigns.read",
      "canvases.read",
      "segments.read"
    ]
  },
  "entry": "SKILL.md",
  "prompts": [
    "prompts/weekly-performance.md"
  ],
  "harnesses": {
    "claude-code": {
      "type": "agent-skill",
      "path": "SKILL.md"
    },
    "codex": {
      "type": "instructions",
      "adapter": "adapters/codex.md"
    },
    "goose": {
      "type": "recipe",
      "adapter": "adapters/goose.yaml"
    },
    "generic": {
      "type": "prompt",
      "path": "SKILL.md"
    }
  },
  "tags": [
    "braze",
    "reporting",
    "kpi",
    "weekly"
  ],
  "license": "MIT",
  "author": "braze-oss"
}
